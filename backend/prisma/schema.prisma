generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  name       String
  password   String?
  avatar     String?
  role       UserRole @default(USER)
  active     Boolean  @default(true)
  provider   String   @default("local")
  providerId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  farms Farm[]

  @@map("users")
}

model PlatformSettings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("platform_settings")
}

model Farm {
  id                   String   @id @default(cuid())
  name                 String
  userId               String
  electricityRate      Float    @default(0.12)
  laborRate            Float    @default(60)
  prepTimeMinutes      Float    @default(10)
  maintenanceRate      Float    @default(0.15)
  targetProfitMargin   Float    @default(50)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  taxRates         TaxRate[]
  printers         Printer[]
  filaments        Filament[]
  salesPlatforms   SalesPlatform[]
  shippingProfiles ShippingProfile[]
  models           Model3D[]

  @@map("farms")
}

model TaxRate {
  id        String   @id @default(cuid())
  farmId    String
  name      String
  rate      Float
  createdAt DateTime @default(now())

  farm Farm @relation(fields: [farmId], references: [id], onDelete: Cascade)

  @@map("tax_rates")
}

model Printer {
  id                    String   @id @default(cuid())
  farmId                String
  brand                 String
  model                 String
  powerConsumption      Float    @default(200)
  purchasePrice         Float    @default(0)
  expectedLifetimeHours Float    @default(5000)
  imageUrl              String?
  preselected           Boolean  @default(false)
  createdAt             DateTime @default(now())

  farm   Farm      @relation(fields: [farmId], references: [id], onDelete: Cascade)
  models Model3D[]

  @@map("printers")
}

model Filament {
  id           String   @id @default(cuid())
  farmId       String
  brand        String
  material     String
  variant      String
  costPerSpool Float    @default(19.99)
  spoolWeight  Float    @default(1000)
  colors       Json     @default("[]")
  createdAt    DateTime @default(now())

  farm               Farm                @relation(fields: [farmId], references: [id], onDelete: Cascade)
  models             Model3D[]
  modelPartFilaments ModelPartFilament[]

  @@map("filaments")
}

enum UserRole {
  USER
  SUPER_ADMIN
}

enum PlatformType {
  ETSY
  AMAZON
  SHOPIFY
  TIKTOK
  EBAY
  CUSTOM
}

model SalesPlatform {
  id         String       @id @default(cuid())
  farmId     String
  type       PlatformType
  shopName   String
  feesConfig Json         @default("{}")
  enabled    Boolean      @default(true)
  createdAt  DateTime     @default(now())

  farm                    Farm                     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  modelPlatformAssignments ModelPlatformAssignment[]

  @@map("sales_platforms")
}

model ShippingProfile {
  id              String   @id @default(cuid())
  farmId          String
  name            String
  customerPays    Float    @default(5.99)
  postageCost     Float    @default(5.00)
  deliveryMinDays Int      @default(3)
  deliveryMaxDays Int      @default(5)
  createdAt       DateTime @default(now())

  farm                    Farm                     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  modelPlatformAssignments ModelPlatformAssignment[]

  @@map("shipping_profiles")
}

model Model3D {
  id                   String   @id @default(cuid())
  farmId               String
  name                 String
  fileName             String
  originalFileName     String?
  slicer               String?
  thumbnailPath        String?
  imagePath            String?
  category             String?
  buildPlateQty        Int      @default(1)
  designer             String?
  marketplaceName      String?
  hasVariations        Boolean  @default(false)
  hasPersonalization   Boolean  @default(false)
  printTimeMinutes     Float
  filamentUsageGrams   Float
  filamentId           String?
  printerId            String?
  // Model-level labor overrides (defaults from farm)
  prepTimeMinutes      Float    @default(1)
  prepCostPerHour      Float?
  postTimeMinutes      Float    @default(1)
  postCostPerHour      Float?
  calculatedCost       Float
  suggestedPrice       Float
  createdAt            DateTime @default(now())

  farm      Farm      @relation(fields: [farmId], references: [id], onDelete: Cascade)
  filament  Filament? @relation(fields: [filamentId], references: [id], onDelete: SetNull)
  printer   Printer?  @relation(fields: [printerId], references: [id], onDelete: SetNull)
  skus      ModelSku[]
  parts     ModelPart[]
  supplies  ModelSupply[]
  platformAssignments ModelPlatformAssignment[]

  @@map("models_3d")
}

model ModelSku {
  id       String @id @default(cuid())
  modelId  String
  sku      String

  model Model3D @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@map("model_skus")
}

model ModelPart {
  id        String @id @default(cuid())
  modelId   String
  name      String @default("Plate 1")
  sortOrder Int    @default(0)

  model     Model3D            @relation(fields: [modelId], references: [id], onDelete: Cascade)
  filaments ModelPartFilament[]

  @@map("model_parts")
}

model ModelPartFilament {
  id         String  @id @default(cuid())
  partId     String
  name       String
  filamentId String?
  grams      Float
  totalCost  Float

  part     ModelPart @relation(fields: [partId], references: [id], onDelete: Cascade)
  filament Filament? @relation(fields: [filamentId], references: [id], onDelete: SetNull)

  @@map("model_part_filaments")
}

model ModelSupply {
  id      String @id @default(cuid())
  modelId String
  name    String
  cost    Float

  model Model3D @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@map("model_supplies")
}

model ModelPlatformAssignment {
  id                String  @id @default(cuid())
  modelId           String
  platformId        String
  shippingProfileId String?
  enabled           Boolean @default(true)

  model           Model3D          @relation(fields: [modelId], references: [id], onDelete: Cascade)
  platform        SalesPlatform    @relation(fields: [platformId], references: [id], onDelete: Cascade)
  shippingProfile ShippingProfile? @relation(fields: [shippingProfileId], references: [id], onDelete: SetNull)

  @@unique([modelId, platformId])
  @@map("model_platform_assignments")
}
